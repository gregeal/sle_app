ENVIRONMENT=production
PUBLIC_ORIGIN=https://sle-prep.example.com
DATABASE_PATH=/var/data/broker.db
STATIC_DIR=/app/web

# Single owner or a small explicit allowlist; comma-separated.
ALLOWED_EMAILS=you@example.com
SESSION_HOURS=12

# Google OAuth is the bootstrap/fallback. Register a passkey after first sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEV_LOGIN_ENABLED=false

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-5-mini
ALLOWED_CHAT_MODELS=gpt-5-mini
REALTIME_MODEL=gpt-realtime
ALLOWED_REALTIME_MODELS=gpt-realtime

REQUESTS_PER_MINUTE=20
DAILY_BUDGET_USD=2.00
MONTHLY_BUDGET_USD=20.00
# Configure these from the provider's current pricing; they are intentionally
# conservative defaults in code, not pricing claims.
CHAT_INPUT_USD_PER_MILLION=5.00
CHAT_OUTPUT_USD_PER_MILLION=20.00
REALTIME_SESSION_RESERVE_USD=1.00
