ENVIRONMENT=production
PUBLIC_ORIGIN=https://sle-prep.example.com
DATABASE_PATH=/var/data/broker.db
STATIC_DIR=/app/web
TRUSTED_HOSTS=*.onrender.com

# Single owner or a small explicit allowlist; comma-separated.
ALLOWED_EMAILS=you@example.com
SESSION_HOURS=12
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Keep this stable, or existing browser profile namespaces will change.
IDENTIFIER_SECRET=

# Google OAuth is the bootstrap/fallback. Register a passkey after first sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEV_LOGIN_ENABLED=false

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-5-mini
ALLOWED_CHAT_MODELS=gpt-5-mini
REALTIME_MODEL=gpt-realtime
ALLOWED_REALTIME_MODELS=gpt-realtime
ALLOWED_REALTIME_VOICES=marin,cedar,coral,sage,verse,alloy,ash,ballad,echo,shimmer
MAX_CHAT_OUTPUT_TOKENS=4000
MAX_REQUEST_BODY_BYTES=262144
OPENAI_MAX_RETRIES=2

REQUESTS_PER_MINUTE=20
AUTH_REQUESTS_PER_MINUTE=10
RATE_LIMIT_MAX_IDENTITIES=5000
DAILY_BUDGET_USD=2.00
MONTHLY_BUDGET_USD=20.00
# Configure these from the provider's current pricing; they are intentionally
# conservative defaults in code, not pricing claims.
CHAT_INPUT_USD_PER_MILLION=5.00
CHAT_OUTPUT_USD_PER_MILLION=20.00
REALTIME_SESSION_RESERVE_USD=1.00

# Persistent metadata maintenance.
CLEANUP_INTERVAL_MINUTES=15
RESERVATION_STALE_MINUTES=60
AUDIT_RETENTION_DAYS=90
USAGE_RETENTION_DAYS=400
